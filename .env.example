# Elasticsearch (required)
MNEMOSYNE_ES_URL=http://localhost:9200

# Embedding model (auto-loaded from embedding_model/ directory)
# Download from HuggingFace, e.g. Qwen/Qwen3-Embedding

# MinerU PDF parsing (optional, uses API if token provided, else local library)
MINERU_API_TOKEN=

# External API (optional, rate-limited without key)
SEMANTIC_SCHOLAR_API_KEY=

# Directory (optional, defaults below)
MNEMOSYNE_INBOX_DIR=./inbox
